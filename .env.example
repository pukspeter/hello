EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787
GOOGLE_CLOUD_PROJECT_ID=your-google-project-id
GOOGLE_VERTEX_LOCATION=europe-west4
GOOGLE_GEMINI_MODEL=gemini-2.5-flash-lite
GOOGLE_STT_LOCATION=global
GOOGLE_STT_LANGUAGE_CODE=et-EE
GOOGLE_STT_MODEL=short
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-google-project-id",...}
# Optional file-path alternative for local/server environments:
GOOGLE_SERVICE_ACCOUNT_PATH=./secrets/google-service-account.json
GOOGLE_TTS_CREDENTIALS_PATH=./secrets/google-tts-service-account.json
GOOGLE_TTS_LANGUAGE_CODE=et-EE
GOOGLE_TTS_VOICE_NAME=et-EE-Chirp3-HD-Autonoe
GOOGLE_TTS_AUDIO_ENCODING=MP3
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=pictograms
PICTOGRAM_IMPORT_DIR=/Users/YOUR_USERNAME/Documents/pictograms
PICTOGRAM_IMPORT_DEFAULT_CATEGORY=Imporditud

# Alternative for local development without a service account key:
# run `gcloud auth application-default login`
# and optionally:
# gcloud auth application-default set-quota-project your-google-project-id
